<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>山水集团学生资源订购系统</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Microsoft YaHei', sans-serif;
            background: #f0f4f8;
            color: #333;
            min-height: 100vh;
        }
        body.scene-bg {
            background:
                linear-gradient(rgba(245, 248, 252, 0.84), rgba(245, 248, 252, 0.94)),
                url('1.jpg') center center / cover fixed no-repeat,
                #f0f4f8;
        }

        /* 顶部导航 */
        header {
            background: linear-gradient(135deg, rgba(26, 115, 232, 0.7), rgba(13, 71, 161, 0.64));
            color: rgb(255, 255, 255);
            padding: 15px 30px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.18);
            box-shadow:
                0 8px 24px rgba(0,0,0,0.14),
                0 0 0 1px rgba(255,255,255,0.06) inset;
            backdrop-filter: blur(14px);
        }
        header .nav-right { display: flex; align-items: center; gap: 15px; }
        .cart-btn {
            background: white;
            color: #1a73e8;
            border: none;
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            font-size: 14px;
        }
        .cart-btn:hover { background: #e8f0fe; }
        body.scene-bg .cart-btn {
            background: rgba(255,255,255,0.18);
            color: white;
            border: 1px solid rgba(255,255,255,0.24);
            box-shadow:
                0 10px 24px rgba(0,0,0,0.14),
                0 0 0 1px rgba(255,255,255,0.08) inset;
            backdrop-filter: blur(18px);
        }
        body.scene-bg .cart-btn:hover {
            background: rgba(255,255,255,0.28);
        }
        .user-info { font-size: 14px; }

        /* 页面容器 */
        .page { display: none; padding: 30px; max-width: 1100px; margin: 0 auto; }
        .page.active { display: block; }

        /* 卡片通用样式 */
        .card {
            background: rgba(255, 255, 255, 0.9);
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 10px 28px rgba(0,0,0,0.12);
            backdrop-filter: blur(10px);
        }
        body.scene-bg #page-cart .card,
        body.scene-bg #page-admin .card {
            background: rgba(255, 255, 255, 0.38) !important;
            border: 1px solid rgba(255,255,255,0.24) !important;
            box-shadow:
                0 18px 38px rgba(0,0,0,0.16),
                0 0 0 1px rgba(255,255,255,0.08) inset !important;
            backdrop-filter: blur(22px) !important;
        }
        .card h2 { margin-bottom: 20px; color: #1a73e8; font-size: 20px; }

        /* 表单 */
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; margin-bottom: 6px; font-weight: bold; font-size: 14px; color: #555; }
        .form-group input, .form-group select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 8px;
            font-size: 14px;
            transition: border 0.2s, background 0.2s, box-shadow 0.2s;
            background: rgba(255,255,255,0.16);
            backdrop-filter: blur(8px);
            color: #1f2937;
        }
        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: #1a73e8;
            background: rgba(255,255,255,0.26);
            box-shadow: 0 0 0 4px rgba(26, 115, 232, 0.14);
        }
        .btn {
            padding: 10px 24px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            transition: all 0.2s;
        }
        .btn-primary { background: #1a73e8; color: white; }
        .btn-primary:hover { background: #1557b0; }
        .btn-secondary { background: #f1f3f4; color: #333; }
        .btn-secondary:hover { background: #e2e5e8; }
        body.scene-bg .btn-secondary {
            background: rgba(255,255,255,0.16);
            color: white;
            border: 1px solid rgba(255,255,255,0.22);
            box-shadow:
                0 8px 20px rgba(0,0,0,0.12),
                0 0 0 1px rgba(255,255,255,0.08) inset;
            backdrop-filter: blur(16px);
        }
        body.scene-bg .btn-secondary:hover {
            background: rgba(255,255,255,0.24);
        }
        .btn-danger { background: #ea4335; color: white; }
        .btn-danger:hover { background: #c5221f; }
        .btn-success { background: #34a853; color: white; }
        .btn-success:hover { background: #2d9146; }

        /* 登录/注册切换 */
        .auth-tabs {
            display: flex;
            gap: 0;
            margin-bottom: 24px;
            border-bottom: 1px solid rgba(255,255,255,0.22);
            background: rgba(255,255,255,0.07);
            border-radius: 14px 14px 0 0;
            padding: 4px 4px 0;
        }
        .auth-tab {
            padding: 10px 24px;
            cursor: pointer;
            font-weight: bold;
            color: rgba(31, 41, 55, 0.66);
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
            border-radius: 10px 10px 0 0;
        }
        .auth-tab.active {
            color: #1a73e8;
            border-bottom-color: #1a73e8;
            background: rgba(255,255,255,0.12);
        }
        .auth-form { display: none; }
        .auth-form.active { display: block; }
        .auth-wrapper { max-width: 420px; margin: 60px auto; }
        #page-auth {
            min-height: calc(100vh - 76px);
            max-width: none;
            margin: 0;
            padding: 40px 20px;
            display: none;
            align-items: center;
            justify-content: center;
            background:
                linear-gradient(rgba(10, 22, 38, 0.42), rgba(10, 22, 38, 0.56)),
                url('2.jpg') center center / cover no-repeat,
                #d8dee6;
        }
        #page-auth.active {
            display: flex;
        }
        #page-auth .card {
            background: rgba(255, 255, 255, 0.3);
            border: 1px solid rgba(255,255,255,0.24);
            backdrop-filter: blur(22px);
            box-shadow:
                0 18px 40px rgba(0,0,0,0.24),
                0 0 0 1px rgba(255,255,255,0.08) inset,
                0 0 34px rgba(125, 181, 255, 0.34),
                0 0 72px rgba(255,255,255,0.18),
                0 0 120px rgba(74, 144, 226, 0.2);
        }
        #page-auth label {
            color: #f8fbff;
            text-shadow: 0 1px 2px rgba(0,0,0,0.28);
        }
        #page-auth input::placeholder {
            color: rgba(31, 41, 55, 0.62);
        }

        .page-banner {
            display: flex;
            justify-content: space-between;
            align-items: stretch;
            gap: 20px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }
        .page-banner-block {
            flex: 1;
            min-width: 280px;
            position: relative;
            overflow: hidden;
            border-radius: 22px;
            padding: 26px 28px;
            box-shadow: 0 18px 40px rgba(21, 87, 176, 0.14);
        }
        .page-banner-block::before {
            content: '';
            position: absolute;
            inset: auto -40px -50px auto;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: rgba(255,255,255,0.14);
        }
        .page-banner-block::after {
            content: '';
            position: absolute;
            inset: 18px 18px auto auto;
            width: 90px;
            height: 90px;
            border-radius: 24px;
            transform: rotate(24deg);
            background: rgba(255,255,255,0.08);
        }
        .page-banner-block > * {
            position: relative;
            z-index: 1;
        }
        .page-banner-brand {
            background: linear-gradient(135deg, #0d47a1 0%, #1976d2 55%, #42a5f5 100%);
            color: white;
        }
        .page-banner-profile {
            background: linear-gradient(135deg, #ffffff 0%, #f6fbff 100%);
            border: 1px solid #d7e7fb;
            padding: 20px 22px;
        }
        .page-banner-label {
            font-size: 12px;
            margin-bottom: 10px;
            letter-spacing: 1.4px;
            font-weight: bold;
            text-transform: uppercase;
        }
        .page-banner-brand .page-banner-label { color: rgba(255,255,255,0.72); }
        .page-banner-profile .page-banner-label { color: #5f6368; }
        .page-banner-title {
            font-size: 30px;
            font-weight: bold;
            line-height: 1.2;
            margin-bottom: 10px;
        }
        .page-banner-brand .page-banner-title { color: white; max-width: 440px; }
        .page-banner-profile .page-banner-title {
            color: #123c7a;
            font-size: 22px;
            margin-bottom: 6px;
        }
        .page-banner-subtitle {
            font-size: 14px;
            line-height: 1.7;
            max-width: 520px;
        }
        .page-banner-brand .page-banner-subtitle { color: rgba(255,255,255,0.82); }
        .page-banner-profile .page-banner-subtitle {
            color: #59708f;
            font-size: 13px;
            line-height: 1.5;
        }
        .banner-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 18px;
        }
        .banner-chip {
            padding: 8px 14px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: bold;
        }
        .page-banner-brand .banner-chip {
            background: rgba(255,255,255,0.14);
            color: white;
            border: 1px solid rgba(255,255,255,0.18);
        }
        .page-banner-profile .banner-chip {
            background: #e8f2ff;
            color: #1557b0;
            border: 1px solid #cfe1fb;
        }
        .student-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            margin-top: 12px;
        }
        .student-meta-item {
            background: rgba(232, 242, 255, 0.68);
            border: 1px solid #d8e7fb;
            border-radius: 16px;
            padding: 10px 12px;
            min-height: 62px;
        }
        .student-meta-key {
            font-size: 12px;
            color: #6b7280;
            margin-bottom: 4px;
        }
        .student-meta-value {
            font-size: 15px;
            font-weight: bold;
            color: #1f2937;
            word-break: break-all;
        }

        /* 商品列表 */
        .filter-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            align-items: center;
        }
        .filter-btn {
            padding: 6px 16px;
            border: 1px solid #ddd;
            background: white;
            border-radius: 20px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        .filter-btn.active, .filter-btn:hover {
            background: #1a73e8;
            color: white;
            border-color: #1a73e8;
        }
        body.scene-bg .filter-btn {
            background: rgba(255,255,255,0.14);
            color: #183153;
            border: 1px solid rgba(255,255,255,0.24);
            box-shadow:
                0 8px 18px rgba(0,0,0,0.1),
                0 0 0 1px rgba(255,255,255,0.08) inset;
            backdrop-filter: blur(14px);
        }
        body.scene-bg .filter-btn.active,
        body.scene-bg .filter-btn:hover {
            background: rgba(26, 115, 232, 0.78);
            color: white;
            border-color: rgba(255,255,255,0.2);
        }
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }
        .product-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
            transition: transform 0.2s, box-shadow 0.2s;
            backdrop-filter: blur(8px);
        }
        body.scene-bg #page-shop .product-card {
            background: rgba(255, 255, 255, 0.34) !important;
            border: 1px solid rgba(255,255,255,0.24) !important;
            box-shadow:
                0 16px 30px rgba(0,0,0,0.16),
                0 0 0 1px rgba(255,255,255,0.08) inset !important;
            backdrop-filter: blur(22px) !important;
        }
        body.scene-bg #page-shop .page-banner-profile,
        body.scene-bg #page-cart .page-banner-profile {
            background: rgba(255,255,255,0.34) !important;
            border: 1px solid rgba(255,255,255,0.24) !important;
            backdrop-filter: blur(22px) !important;
            box-shadow:
                0 16px 34px rgba(0,0,0,0.14),
                0 0 0 1px rgba(255,255,255,0.08) inset !important;
        }
        body.scene-bg #page-shop .student-meta-item,
        body.scene-bg #page-cart .student-meta-item {
            background: rgba(255,255,255,0.18) !important;
            border-color: rgba(255,255,255,0.22) !important;
        }
        .product-card:hover { transform: translateY(-4px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
        .product-icon {
            height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 56px;
        }
        .product-info { padding: 14px; }
        .product-name { font-weight: bold; font-size: 15px; margin-bottom: 4px; }
        .product-type { font-size: 12px; color: #888; margin-bottom: 8px; }
        .product-stock { font-size: 12px; color: #34a853; margin-bottom: 10px; }
        .product-stock.low { color: #ea4335; }
        .product-bottom { display: flex; justify-content: space-between; align-items: center; }
        .product-price { font-size: 18px; font-weight: bold; color: #ea4335; }
        .add-cart-btn {
            background: #1a73e8;
            color: white;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }
        .add-cart-btn:hover { background: #1557b0; }
        .add-cart-btn:disabled { background: #ccc; cursor: not-allowed; }

        /* 购物车 */
        .cart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .cart-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid #f0f0f0;
        }
        .cart-item-icon { font-size: 36px; min-width: 50px; text-align: center; }
        .cart-item-info { flex: 1; }
        .cart-item-name { font-weight: bold; margin-bottom: 4px; }
        .cart-item-type { font-size: 12px; color: #888; }
        .cart-item-qty {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .qty-btn {
            width: 28px; height: 28px;
            border-radius: 50%;
            border: 1px solid #ddd;
            background: white;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .qty-btn:hover { background: #f0f0f0; }
        .qty-num { min-width: 24px; text-align: center; font-weight: bold; }
        .cart-item-price { font-weight: bold; color: #ea4335; min-width: 70px; text-align: right; }
        .remove-btn { color: #ea4335; background: none; border: none; cursor: pointer; font-size: 18px; }
        .cart-summary {
            margin-top: 20px;
            padding-top: 16px;
            border-top: 2px solid #e8eaed;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 15px;
        }
        .summary-total {
            font-size: 20px;
            font-weight: bold;
            color: #ea4335;
        }
        .cart-actions { margin-top: 20px; display: flex; gap: 12px; justify-content: flex-end; }
        .empty-cart { text-align: center; padding: 40px; color: #888; font-size: 16px; }
        .empty-cart .empty-icon { font-size: 60px; margin-bottom: 12px; }

        /* 结账弹窗 */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.show { display: flex; }
        .modal-box {
            background: white;
            border-radius: 16px;
            padding: 36px;
            max-width: 420px;
            width: 90%;
            text-align: center;
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            animation: popIn 0.3s ease;
        }
        @keyframes popIn {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .wechat-icon { font-size: 80px; margin: 16px 0; }
        .wechat-qr {
            width: 160px;
            height: 160px;
            background: #f0f4f8;
            border: 2px solid #07c160;
            border-radius: 12px;
            margin: 16px auto;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: #888;
        }
        .modal-title { font-size: 22px; font-weight: bold; color: #07c160; margin-bottom: 8px; }
        .modal-subtitle { color: #666; font-size: 14px; margin-bottom: 20px; }
        .modal-amount { font-size: 28px; font-weight: bold; color: #ea4335; margin: 12px 0; }

        .product-modal-box {
            max-width: 460px;
            text-align: left;
        }
        .product-modal-head {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
        }
        .product-modal-icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            flex-shrink: 0;
        }
        .product-modal-name {
            font-size: 22px;
            font-weight: bold;
            color: #b9eaff;
        }
        .product-modal-type {
            font-size: 13px;
            color: #d9eeff;
            margin-top: 3px;
        }
        .product-modal-desc {
            font-size: 14px;
            line-height: 1.65;
            color: #d9eeff;
            margin-bottom: 14px;
        }
        .product-modal-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            gap: 10px;
            flex-wrap: wrap;
        }
        .product-modal-price {
            font-size: 26px;
            font-weight: bold;
            color: #ff8a80;
        }
        .product-modal-stock {
            font-size: 14px;
            color: #9fe7ff;
        }
        .product-modal-stock.low {
            color: #ff9f9a;
        }
        .product-modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .confirm-modal-box {
            max-width: 420px;
            text-align: left;
        }
        .confirm-modal-title {
            font-size: 22px;
            font-weight: bold;
            color: #b9eaff;
            margin-bottom: 10px;
        }
        .confirm-modal-message {
            color: #d9eeff;
            line-height: 1.65;
            margin-bottom: 22px;
        }
        .confirm-modal-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }

        /* 通知 */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: #333;
            color: white;
            padding: 12px 24px;
            border-radius: 24px;
            font-size: 14px;
            opacity: 0;
            transition: all 0.3s;
            z-index: 2000;
        }
        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        /* 错误提示 */
        .error-msg { color: #ea4335; font-size: 13px; margin-top: 6px; display: none; }
        .error-msg.show { display: block; }

        /* 徽章 */
        .badge {
            background: #ea4335;
            color: white;
            border-radius: 10px;
            padding: 2px 7px;
            font-size: 12px;
            font-weight: bold;
            margin-left: 4px;
        }

        /* 管理员后台 */
        .admin-btn {
            background: #f9ab00;
            color: #333;
            border: none;
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            font-size: 13px;
        }
        .admin-btn:hover { background: #f29900; }
        body.scene-bg .admin-btn {
            background: rgba(249, 171, 0, 0.2);
            color: white;
            border: 1px solid rgba(255,255,255,0.22);
            box-shadow:
                0 10px 22px rgba(0,0,0,0.12),
                0 0 0 1px rgba(255,255,255,0.08) inset;
            backdrop-filter: blur(16px);
        }
        body.scene-bg .admin-btn:hover {
            background: rgba(249, 171, 0, 0.3);
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }
        .stat-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            text-align: center;
        }
        .stat-icon { font-size: 36px; margin-bottom: 8px; }
        .stat-num { font-size: 28px; font-weight: bold; color: #1a73e8; }
        .stat-label { font-size: 13px; color: #888; margin-top: 4px; }
        .admin-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }
        .admin-table th {
            background: #f0f4f8;
            padding: 12px 14px;
            text-align: left;
            font-weight: bold;
            color: #555;
            border-bottom: 2px solid #e0e0e0;
        }
        .admin-table td {
            padding: 11px 14px;
            border-bottom: 1px solid #f0f0f0;
            vertical-align: middle;
        }
        .admin-table tr:hover td { background: #f9fafb; }
        .admin-tabs { display: flex; gap: 0; margin-bottom: 20px; border-bottom: 2px solid #e8eaed; }
        .admin-tab {
            padding: 10px 22px;
            cursor: pointer;
            font-weight: bold;
            color: #888;
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
