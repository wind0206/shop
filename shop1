        { id: 8, name: 'Python进阶', type: '书籍', price: 29.00, stock: 3, desc: '深入理解Python高级特性' },
        { id: 9, name: '平板电脑', type: '电脑', price: 2599.00, stock: 10, desc: '高清屏幕，支持手写笔，学习神器' },
        { id: 10, name: 'USB插排', type: '插头', price: 89.00, stock: 14, desc: '6口USB插排，宿舍必备' },
        { id: 11, name: '编程入门课', type: 'DVD', price: 55.00, stock: 7, desc: 'Python与C++基础教程' },
        { id: 12, name: '计算机入门', type: '书籍', price: 18.00, stock: 30, desc: '帮你快速掌握计算机基础知识' },
    ];

    let activeFilter = '全部';
    let stockMap = {};
    let currentModalProductId = null;
    products.forEach(p => { stockMap[p.id] = p.stock; });

    // ===== 账户管理 =====
    function saveAccounts() { localStorage.setItem('shopAccounts', JSON.stringify(accounts)); }
    function saveUser() { localStorage.setItem('shopCurrentUser', JSON.stringify(currentUser)); }
    function saveCart() { localStorage.setItem('shopCart', JSON.stringify(cart)); }
    function saveOrders() { localStorage.setItem('shopOrders', JSON.stringify(orders)); }

    function updateStudentPanels() {
        const profile = currentUser || {};
        const fields = {
            name: profile.name || '未登录',
            studentId: profile.studentId || '-',
            className: profile.className || '-',
            username: profile.username || '-'
        };

        document.getElementById('shopStudentName').textContent = fields.name;
        document.getElementById('shopStudentId').textContent = fields.studentId;
        document.getElementById('shopStudentClass').textContent = fields.className;
        document.getElementById('shopStudentUser').textContent = fields.username;

        document.getElementById('cartStudentName').textContent = fields.name;
        document.getElementById('cartStudentId').textContent = fields.studentId;
        document.getElementById('cartStudentClass').textContent = fields.className;
        document.getElementById('cartStudentUser').textContent = fields.username;
    }

    function switchTab(tab) {
        document.querySelectorAll('.auth-tab').forEach((t, i) => {
            t.classList.toggle('active', (i === 0 && tab === 'login') || (i === 1 && tab === 'register'));
        });
        document.getElementById('loginForm').classList.toggle('active', tab === 'login');
        document.getElementById('registerForm').classList.toggle('active', tab === 'register');
    }

    function login() {
        const user = document.getElementById('loginUser').value.trim();
        const pass = document.getElementById('loginPass').value;
        // 同时支持用户名和学号登录
        const found = accounts.find(a =>
            (a.username === user || a.studentId === user) && a.password === pass
        );
        document.getElementById('loginError').classList.toggle('show', !found);
        if (found) {
            currentUser = found;
            saveUser();
            showToast(`欢迎回来，${found.name}！`);
            enterShop();
        }
    }

    function register() {
        const name = document.getElementById('regName').value.trim();
        const id = document.getElementById('regId').value.trim();
        const cls = document.getElementById('regClass').value.trim();
        const user = document.getElementById('regUser').value.trim();
        const pass = document.getElementById('regPass').value;
        const pass2 = document.getElementById('regPass2').value;

        let valid = true;
        document.getElementById('regUserError').classList.remove('show');
        document.getElementById('regPassError').classList.remove('show');
        document.getElementById('regPass2Error').classList.remove('show');

        if (!name || !id || !cls || !user || !pass || !pass2) {
            showToast('请填写所有信息');
            return;
        }
        if (accounts.find(a => a.username === user)) {
            document.getElementById('regUserError').classList.add('show');
            valid = false;
        }
        if (pass.length < 6) {
            document.getElementById('regPassError').classList.add('show');
            valid = false;
        }
        if (pass !== pass2) {
            document.getElementById('regPass2Error').classList.add('show');
            valid = false;
        }
        if (!valid) return;

        const newAccount = { username: user, password: pass, name, studentId: id, className: cls };
        accounts.push(newAccount);
        saveAccounts();
        currentUser = newAccount;
        saveUser();
        showToast(`账户创建成功！欢迎，${name}！`);
        enterShop();
    }

    function enterShop() {
        document.getElementById('cartBtn').style.display = '';
        document.getElementById('shopNavBtn').style.display = '';
        document.getElementById('logoutBtn').style.display = '';
        updateStudentPanels();
        updateCartBadge();
        showPage('shop');
        renderProducts();
    }

    function logout() {
        currentUser = null;
        cart = [];
        saveUser();
        saveCart();
        document.getElementById('cartBtn').style.display = 'none';
        document.getElementById('shopNavBtn').style.display = 'none';
        document.getElementById('logoutBtn').style.display = 'none';
        updateStudentPanels();
        showPage('auth');
        showToast('已退出登录');
    }

    // ===== 页面切换 =====
    function showPage(name) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById('page-' + name).classList.add('active');
        document.body.classList.toggle('scene-bg', name === 'shop' || name === 'cart');
        if (name === 'cart') renderCart();
    }

    // ===== 商品渲染 =====
    function renderProducts() {
        // 过滤按钮
        const types = ['全部', ...new Set(products.map(p => p.type))];
        const filterBar = document.getElementById('filterBar');
        filterBar.innerHTML = types.map(t =>
            `<button class="filter-btn ${t === activeFilter ? 'active' : ''}" onclick="setFilter('${t}')">${typeIcons[t] || '📦'} ${t}</button>`
        ).join('');

        const filtered = activeFilter === '全部' ? products : products.filter(p => p.type === activeFilter);
        document.getElementById('productsGrid').innerHTML = filtered.map(p => {
            const stock = stockMap[p.id];
            const cartItem = cart.find(c => c.id === p.id);
            const cartQty = cartItem ? cartItem.qty : 0;
            const available = stock - cartQty;
            return `
            <div class="product-card" onclick="openProductModal(${p.id})" style="cursor:pointer">
                <div class="product-icon" style="background:${typeColors[p.type] || '#f0f4f8'}">${typeIcons[p.type] || '📦'}</div>
                <div class="product-info">
                    <div class="product-name">${p.name}</div>
                    <div class="product-type">${p.type}</div>
                    <div class="product-stock ${available <= 3 ? 'low' : ''}">
                        ${available <= 0 ? '已售完' : available <= 3 ? `仅剩 ${available} 件` : `库存 ${available} 件`}
                    </div>
                    <div class="product-bottom">
                        <div class="product-price">¥${p.price.toFixed(2)}</div>
                        <button class="add-cart-btn" onclick="event.stopPropagation();addToCart(${p.id})" ${available <= 0 ? 'disabled' : ''}>+</button>
                    </div>
                </div>
            </div>`;
        }).join('');
    }

    function setFilter(type) {
        activeFilter = type;
        renderProducts();
    }

    // ===== 购物车操作 =====
    function addToCart(productId) {
        const p = products.find(x => x.id === productId);
        const existing = cart.find(c => c.id === productId);
        const cartQty = existing ? existing.qty : 0;
        if (cartQty >= stockMap[productId]) {
            showToast('库存不足！');
            return;
        }
        if (existing) {
            existing.qty++;
        } else {
            cart.push({ id: p.id, name: p.name, type: p.type, price: p.price, qty: 1 });
        }
        saveCart();
        updateCartBadge();
        renderProducts();
        showToast('添加成功');
    }

    function changeQty(productId, delta) {
        const item = cart.find(c => c.id === productId);
        if (!item) return;
        item.qty += delta;
        if (item.qty <= 0) {
            cart = cart.filter(c => c.id !== productId);
        }
        saveCart();
        updateCartBadge();
        renderCart();
        renderProducts();
    }

    function removeFromCart(productId) {
        cart = cart.filter(c => c.id !== productId);
        saveCart();
        updateCartBadge();
        renderCart();
        renderProducts();
        showToast('已移除');
    }

    function clearCart() {
        cart = [];
        saveCart();
        updateCartBadge();
        renderCart();
        renderProducts();
        showToast('购物车已清空');
    }

    function requestClearCart() {
        openConfirmModal({
            title: '清空购物车',
            message: '确定要清空购物车中的所有商品吗？此操作不可撤销。',
            okText: '确认清空',
            onConfirm: () => clearCart()
        });
    }

    function updateCartBadge() {
        const total = cart.reduce((sum, c) => sum + c.qty, 0);
        document.getElementById('cartBadge').textContent = total;
    }

    function renderCart() {
        const container = document.getElementById('cartContent');
        if (cart.length === 0) {
            container.innerHTML = `<div class="empty-cart"><div class="empty-icon">🛒</div><p>购物车空空如也</p><br><button class="btn btn-primary" onclick="showPage('shop')">去挑选商品</button></div>`;
            return;
        }

        const subtotal = cart.reduce((sum, c) => sum + c.price * c.qty, 0);
        const shipping = 0;
        const total = subtotal + shipping;

        container.innerHTML = `
            ${cart.map(item => `
            <div class="cart-item">
                <div class="cart-item-icon">${typeIcons[item.type] || '📦'}</div>
                <div class="cart-item-info">
                    <div class="cart-item-name">${item.name}</div>
                    <div class="cart-item-type">${item.type} · ¥${item.price.toFixed(2)}/件</div>
                </div>
                <div class="cart-item-qty">
                    <button class="qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
                    <span class="qty-num">${item.qty}</span>
                    <button class="qty-btn" onclick="changeQty(${item.id}, 1)">+</button>
                </div>
                <div class="cart-item-price">¥${(item.price * item.qty).toFixed(2)}</div>
                <button class="remove-btn" onclick="removeFromCart(${item.id})">🗑</button>
            </div>`).join('')}
            <div class="cart-summary">
                <div class="summary-row"><span>商品合计</span><span>¥${subtotal.toFixed(2)}</span></div>
                <div class="summary-row"><span>配送费</span><span style="color:#34a853">免费</span></div>
                <div class="summary-row summary-total"><span>应付总额</span><span>¥${total.toFixed(2)}</span></div>
            </div>
            <div class="cart-actions">
                <button class="btn btn-secondary" onclick="requestClearCart()">清空购物车</button>
                <button class="btn btn-success" onclick="checkout(${total.toFixed(2)})">💳 立即结账</button>
            </div>`;
    }

    // ===== 结账 =====
    function checkout(amount) {
        document.getElementById('payAmount').textContent = `¥${parseFloat(amount).toFixed(2)}`;
        document.getElementById('wechatModal').classList.add('show');
    }

    function closeModal() {
        document.getElementById('wechatModal').classList.remove('show');
    }

    function openProductModal(productId) {
        const product = products.find(p => p.id === productId);
        if (!product) return;

        const cartItem = cart.find(c => c.id === product.id);
        const cartQty = cartItem ? cartItem.qty : 0;
        const available = stockMap[product.id] - cartQty;

        currentModalProductId = product.id;
        document.getElementById('productModalIcon').textContent = typeIcons[product.type] || '📦';
        document.getElementById('productModalIcon').style.background = typeColors[product.type] || '#f0f4f8';
        document.getElementById('productModalName').textContent = product.name;
        document.getElementById('productModalType').textContent = `${product.type} · 编号 ${product.id}`;
        document.getElementById('productModalDesc').textContent = product.desc || '暂无商品描述';
        document.getElementById('productModalPrice').textContent = `¥${product.price.toFixed(2)}`;

        const stockEl = document.getElementById('productModalStock');
        stockEl.textContent = available <= 0 ? '已售完' : available <= 3 ? `仅剩 ${available} 件` : `库存 ${available} 件`;
        stockEl.classList.toggle('low', available <= 3);

        const addBtn = document.getElementById('productModalAddBtn');
        addBtn.disabled = available <= 0;
        addBtn.textContent = available <= 0 ? '已售完' : '加入购物车';

        document.getElementById('productModal').classList.add('show');
    }

    function closeProductModal() {
        document.getElementById('productModal').classList.remove('show');
        currentModalProductId = null;
    }

    function addToCartFromModal() {
        if (!currentModalProductId) return;
        addToCart(currentModalProductId);
        openProductModal(currentModalProductId);
    }

    function openConfirmModal(options) {
        document.getElementById('confirmModalTitle').textContent = options.title || '操作确认';
        document.getElementById('confirmModalMessage').textContent = options.message || '你确定要继续吗？';
        document.getElementById('confirmModalOkBtn').textContent = options.okText || '确认';
        confirmAction = typeof options.onConfirm === 'function' ? options.onConfirm : null;
        document.getElementById('confirmModal').classList.add('show');
    }

    function closeConfirmModal() {
        document.getElementById('confirmModal').classList.remove('show');
        confirmAction = null;
    }

    function handleConfirmModalOk() {
        const action = confirmAction;
        closeConfirmModal();
        if (action) action();
    }

    function confirmPayment() {
        closeModal();
        // 保存订单记录
        const order = {
            id: Date.now(),
            user: currentUser.name,
            studentId: currentUser.studentId,
            className: currentUser.className,
            items: cart.map(c => ({ name: c.name, type: c.type, qty: c.qty, price: c.price })),
            total: cart.reduce((s, c) => s + c.price * c.qty, 0),
            time: new Date().toLocaleString('zh-CN')
        };
        orders.push(order);
        saveOrders();
        cart = [];
        saveCart();
        updateCartBadge();
        renderProducts();
        showPage('shop');
        showToast('🎉 支付成功！订单已确认，感谢您的订购！');
    }

    // ===== 管理员后台 =====
    function openAdminLogin() {
        document.getElementById('adminPassInput').value = '';
        document.getElementById('adminPassError').classList.remove('show');
        document.getElementById('adminLoginModal').classList.add('show');
        setTimeout(() => document.getElementById('adminPassInput').focus(), 100);
    }
    function closeAdminLogin() {
        document.getElementById('adminLoginModal').classList.remove('show');
    }
    function verifyAdmin() {
        const pass = document.getElementById('adminPassInput').value;
        if (pass === ADMIN_PASSWORD) {
            closeAdminLogin();
            document.getElementById('adminBackBtn').style.display = currentUser ? '' : 'none';
            showPage('admin');
            renderAdminStats();
            renderAdminUsers();
            renderAdminOrders();
        } else {
            document.getElementById('adminPassError').classList.add('show');
        }
    }
    function switchAdminTab(tab) {
        document.querySelectorAll('.admin-tab').forEach((t, i) => {
            t.classList.toggle('active', (i === 0 && tab === 'users') || (i === 1 && tab === 'orders'));
        });
        document.getElementById('adminUsers').classList.toggle('active', tab === 'users');
        document.getElementById('adminOrders').classList.toggle('active', tab === 'orders');
    }
    function renderAdminStats() {
        const totalOrders = orders.length;
        const totalRevenue = orders.reduce((s, o) => s + o.total, 0);
        const totalUsers = accounts.length;
        const todayOrders = orders.filter(o => o.time.startsWith(new Date().toLocaleDateString('zh-CN'))).length;
        document.getElementById('adminStats').innerHTML = `
            <div class="stat-card"><div class="stat-icon">👥</div><div class="stat-num">${totalUsers}</div><div class="stat-label">注册账户</div></div>
            <div class="stat-card"><div class="stat-icon">📦</div><div class="stat-num">${totalOrders}</div><div class="stat-label">累计订单</div></div>
            <div class="stat-card"><div class="stat-icon">💰</div><div class="stat-num">¥${totalRevenue.toFixed(2)}</div><div class="stat-label">累计收入</div></div>
            <div class="stat-card"><div class="stat-icon">📅</div><div class="stat-num">${todayOrders}</div><div class="stat-label">今日订单</div></div>
        `;
    }
    function renderAdminUsers() {
        const keyword = (document.getElementById('userSearch')?.value || '').toLowerCase();
        const filtered = accounts.filter(a =>
            a.name.toLowerCase().includes(keyword) ||
            a.studentId.toLowerCase().includes(keyword) ||
            a.username.toLowerCase().includes(keyword)
        );
        if (filtered.length === 0) {
            document.getElementById('adminUsersTable').innerHTML = '<p style="color:#888;padding:20px 0">暂无账户数据</p>';
            return;
        }
        document.getElementById('adminUsersTable').innerHTML = `
            <table class="admin-table">
                <thead><tr>
                    <th>#</th><th>姓名</th><th>学号</th><th>班级</th><th>用户名</th><th>订单数</th><th>操作</th>
                </tr></thead>
                <tbody>${filtered.map((a, i) => {
                    const userOrders = orders.filter(o => o.studentId === a.studentId).length;
                    return `<tr>
                        <td>${i + 1}</td>
                        <td><strong>${a.name}</strong></td>
                        <td><span class="tag tag-blue">${a.studentId}</span></td>
                        <td>${a.className}</td>
                        <td>${a.username}</td>
                        <td><span class="tag tag-green">${userOrders} 单</span></td>
                        <td><button class="del-user-btn" onclick="deleteUser('${a.username}')">删除</button></td>
                    </tr>`;
                }).join('')}</tbody>
            </table>`;
    }
    function deleteUser(username) {
        openConfirmModal({
            title: '删除账户',
            message: `确定要删除用户“${username}”吗？删除后无法恢复。`,
            okText: '确认删除',
            onConfirm: () => {
                accounts = accounts.filter(a => a.username !== username);
                saveAccounts();
                renderAdminStats();
                renderAdminUsers();
                showToast('用户已删除');
            }
        });
    }
    function renderAdminOrders() {
        if (orders.length === 0) {
            document.getElementById('adminOrdersTable').innerHTML = '<p style="color:#888;padding:20px 0">暂无订单记录</p>';
            return;
        }
        const sorted = [...orders].reverse();
        document.getElementById('adminOrdersTable').innerHTML = `
            <table class="admin-table">
                <thead><tr>
                    <th>时间</th><th>学生</th><th>班级</th><th>商品</th><th>总金额</th>
                </tr></thead>
                <tbody>${sorted.map(o => `<tr>
                    <td style="color:#888;font-size:12px">${o.time}</td>
                    <td><strong>${o.user}</strong><br><span style="font-size:12px;color:#888">${o.studentId}</span></td>
                    <td>${o.className}</td>
                    <td>${o.items.map(it => `${it.name}×${it.qty}`).join('、')}</td>
                    <td><strong style="color:#ea4335">¥${o.total.toFixed(2)}</strong></td>
                </tr>`).join('')}</tbody>
            </table>`;
    }

    // ===== 工具 =====
    function showToast(msg) {
        const toast = document.getElementById('toast');
        toast.textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2500);
    }

    window.addEventListener('click', (event) => {
        if (event.target.id === 'confirmModal') closeConfirmModal();
        if (event.target.id === 'adminLoginModal') closeAdminLogin();
        if (event.target.id === 'wechatModal') closeModal();
        if (event.target.id === 'productModal') closeProductModal();
    });

    // ===== 初始化 =====
    if (currentUser) {
        // 检查currentUser是否仍在accounts中（防止账户被删除后异常）
        const stillExists = accounts.find(a => a.username === currentUser.username);
        if (stillExists) {
            enterShop();
        } else {
            currentUser = null;
            localStorage.removeItem('shopCurrentUser');
        }
    }
    updateStudentPanels();
</script>
</body>
</html>
